{
  "manifest_version": 3,
  "name": "Content Forge Scraper",
  "version": "1.0.0",
  "description": "Scrape any social platform and send data to Content Forge for AI analysis. Pro feature.",
  "permissions": [
    "activeTab",
    "storage",
    "scripting"
  ],
  "host_permissions": [
    "https://www.tiktok.com/*",
    "https://www.instagram.com/*",
    "https://www.youtube.com/*",
    "https://x.com/*",
    "https://twitter.com/*",
    "https://www.linkedin.com/*",
    "https://www.facebook.com/*",
    "https://www.reddit.com/*",
    "https://www.threads.net/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.tiktok.com/*",
        "https://www.instagram.com/*",
        "https://www.youtube.com/*",
        "https://x.com/*",
        "https://twitter.com/*",
        "https://www.linkedin.com/*",
        "https://www.facebook.com/*",
        "https://www.reddit.com/*",
        "https://www.threads.net/*"
      ],
      "js": ["content.js"],
      "css": ["content.css"]
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
